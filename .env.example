VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtydnR6dGZtZXl6bm1nbGVsd2ZyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODMxNTQ0MTUsImV4cCI6MjA5ODczMDQxNX0.8e0DNmdjUliwjicV1PlsA1pZujkPTeZoVp5yjyFbWJs

# ── Meta App (Facebook/Instagram) OAuth — used by the frontend to start login ──
VITE_META_APP_ID=your_meta_app_id

# ── Meta App (Facebook/Instagram) — get from developers.facebook.com ────
# These go in Supabase Edge Function secrets, NEVER in the frontend .env.
# Set with: supabase secrets set META_APP_ID=xxx META_APP_SECRET=xxx
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=choose_a_long_random_string
META_GRAPH_API_VERSION=v20.0

# ── WhatsApp Business Platform (Cloud API) ───────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_waba_id
WHATSAPP_ACCESS_TOKEN=your_system_user_permanent_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=choose_a_long_random_string

# ── Token encryption (Edge Functions only) ───────────────────────────────
# 32-byte random key, base64. Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=generate_me

# ── Supabase service role (Edge Functions only, never client-side) ──────
SUPABASE_SERVICE_ROLE_KEY=paste_service_role_key_here
